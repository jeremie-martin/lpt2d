{
  "version": 4,
  "name": "three_spheres",
  "camera": { "bounds": [-1.3, -0.9, 1.3, 0.9] },
  "canvas": { "width": 1920, "height": 1080 },
  "look": { "exposure": 2, "tonemap": "aces", "normalize": "rays" },
  "trace": { "rays": 10000000, "batch": 200000, "depth": 12 },
  "materials": {
    "glass": {
      "ior": 1.5,
      "transmission": 1,
      "absorption": 0.5,
      "cauchy_b": 20000
    },
    "mirror_wall": {
      "metallic": 1,
      "transmission": 1,
      "albedo": 0.95
    }
  },
  "shapes": [
    { "type": "circle", "center": [-0.5, 0], "radius": 0.2, "material": "glass" },
    { "type": "circle", "center": [0, 0], "radius": 0.2, "material": "glass" },
    { "type": "circle", "center": [0.5, 0], "radius": 0.2, "material": "glass" },
    { "type": "segment", "a": [-1.2, -0.8], "b": [1.2, -0.8], "material": "mirror_wall" },
    { "type": "segment", "a": [1.2, 0.8], "b": [-1.2, 0.8], "material": "mirror_wall" },
    { "type": "segment", "a": [-1.2, 0.8], "b": [-1.2, -0.8], "material": "mirror_wall" },
    { "type": "segment", "a": [1.2, -0.8], "b": [1.2, 0.8], "material": "mirror_wall" }
  ],
  "lights": [
    { "type": "point", "pos": [-0.8, 0.5], "intensity": 1 },
    { "type": "point", "pos": [0.8, -0.5], "intensity": 1 }
  ]
}
