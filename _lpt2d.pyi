        lights: Sequence[PointLight | SegmentLight | ProjectorLight] = [],
    ) -> None: ...
    @property
    def id(self) -> str: ...
    @id.setter
    def id(self, arg: str, /) -> None: ...
    @property
    def transform(self) -> Transform2D: ...
    @transform.setter
    def transform(self, arg: Transform2D, /) -> None: ...
    @property
    def shapes(self) -> list[Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path]: ...
    @shapes.setter
    def shapes(
        self, arg: Sequence[Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path], /
    ) -> None: ...
    @property
