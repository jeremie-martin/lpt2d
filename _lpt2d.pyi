    @lights.setter
    def lights(self, arg: Sequence[PointLight | SegmentLight | ProjectorLight], /) -> None: ...

class Scene:
    def __init__(
        self,
        shapes: Sequence[Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path] = [],
        lights: Sequence[PointLight | SegmentLight | ProjectorLight] = [],
        groups: Sequence[Group] = [],
        materials: Mapping[str, Material] = {},
    ) -> None: ...
    @property
    def shapes(self) -> list[Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path]: ...
    @shapes.setter
    def shapes(
        self, arg: Sequence[Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path], /
    ) -> None: ...
    @property
    def lights(self) -> list[PointLight | SegmentLight | ProjectorLight]: ...
    @lights.setter
    def lights(self, arg: Sequence[PointLight | SegmentLight | ProjectorLight], /) -> None: ...
    @property
    def groups(self) -> list[Group]: ...
    @groups.setter
    def groups(self, arg: Sequence[Group], /) -> None: ...
    @property
    def materials(self) -> dict[str, Material]: ...
    @materials.setter
    def materials(self, arg: Mapping[str, Material], /) -> None: ...

    # monkey-patched by anim.types
    def find_shape(
        self, entity_id: str
    ) -> Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path | None: ...
    def find_light(self, entity_id: str) -> PointLight | SegmentLight | ProjectorLight | None: ...
    def find_group(self, entity_id: str) -> Group | None: ...
    def clone(self) -> Scene: ...
    def require_shape(
        self, entity_id: str
    ) -> Circle | Segment | Arc | Bezier | Polygon | Ellipse | Path: ...
    def require_light(self, entity_id: str) -> PointLight | SegmentLight | ProjectorLight: ...
    def require_group(self, entity_id: str) -> Group: ...
    def require_material(self, material_id: str) -> Material: ...

