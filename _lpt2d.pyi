"""lpt2d core C++ bindings"""

import enum
from collections.abc import Mapping, Sequence
from typing import Any

# Return type from C++ properties — always a tuple
Vec2 = tuple[float, float]
# Input type accepted by nanobind — tuples and lists both work at runtime
Vec2Like = tuple[float, float] | list[float] | Sequence[float]

class ToneMap(enum.Enum):
    none = 0

    reinhard = 1

    reinhardx = 2

    aces = 3

    log = 4

class NormalizeMode(enum.Enum):
    max = 0

    rays = 1

    fixed = 2

    off = 3

class SeedMode(enum.Enum):
    deterministic = 0

    decorrelated = 1

class ProjectorProfile(enum.Enum):
    uniform = 0

    soft = 1

    gaussian = 2

class ProjectorSource(enum.Enum):
    line = 0

    ball = 1

class PolygonJoinMode(enum.Enum):
    auto = 0

    sharp = 1

    smooth = 2

class Material:
    def __init__(
        self,
        ior: float = 1.0,
        roughness: float = 0.0,
        metallic: float = 0.0,
        transmission: float = 0.0,
        absorption: float = 0.0,
        cauchy_b: float = 0.0,
        albedo: float = 1.0,
        emission: float = 0.0,
        spectral_c0: float = 0.0,
        spectral_c1: float = 0.0,
        spectral_c2: float = 0.0,
        fill: float = 0.0,
    ) -> None: ...
    @property
    def ior(self) -> float: ...
    @ior.setter
    def ior(self, arg: float, /) -> None: ...
    @property
    def roughness(self) -> float: ...
    @roughness.setter
    def roughness(self, arg: float, /) -> None: ...
    @property
    def metallic(self) -> float: ...
    @metallic.setter
    def metallic(self, arg: float, /) -> None: ...
    @property
    def transmission(self) -> float: ...
    @transmission.setter
    def transmission(self, arg: float, /) -> None: ...
    @property
    def absorption(self) -> float: ...
    @absorption.setter
    def absorption(self, arg: float, /) -> None: ...
    @property
    def cauchy_b(self) -> float: ...
    @cauchy_b.setter
    def cauchy_b(self, arg: float, /) -> None: ...
    @property
    def albedo(self) -> float: ...
    @albedo.setter
    def albedo(self, arg: float, /) -> None: ...
    @property
    def emission(self) -> float: ...
    @emission.setter
    def emission(self, arg: float, /) -> None: ...
    @property
    def spectral_c0(self) -> float: ...
    @spectral_c0.setter
    def spectral_c0(self, arg: float, /) -> None: ...
    @property
    def spectral_c1(self) -> float: ...
    @spectral_c1.setter
    def spectral_c1(self, arg: float, /) -> None: ...
    @property
    def spectral_c2(self) -> float: ...
    @spectral_c2.setter
    def spectral_c2(self, arg: float, /) -> None: ...
    @property
    def fill(self) -> float: ...
    @fill.setter
    def fill(self, arg: float, /) -> None: ...
    def __eq__(self, arg: Material, /) -> bool: ...
    def __repr__(self) -> str: ...

def glass(ior: float = 1.5, cauchy_b: float = 0.0, absorption: float = 0.0) -> Material: ...
def mirror(reflectance: float, roughness: float = 0.0) -> Material: ...
def opaque_mirror(reflectance: float, roughness: float = 0.0) -> Material: ...
def diffuse(reflectance: float) -> Material: ...
def absorber() -> Material: ...
def emissive(emission: float, base: Material = ...) -> Material: ...
def beam_splitter(reflectance: float, roughness: float = 0.0) -> Material: ...
def named_color(name: str) -> tuple: ...
def spectral_fill_rgb(c0: float, c1: float, c2: float) -> tuple: ...
def rgb_to_spectral(r: float, g: float, b: float) -> tuple: ...
def named_color_list() -> list: ...

